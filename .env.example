# PhantomFeed Environment Configuration
# Copy this file to .env and fill in your values
# All keys are optional — PhantomFeed works without them at reduced rate limits

# NVD API Key (free at https://nvd.nist.gov/developers/request-an-api-key)
# Without: 5 req/30s   With: 50 req/30s
NVD_API_KEY=

# AlienVault OTX API Key (free at https://otx.alienvault.com)
# Required to ingest OTX threat pulses
OTX_API_KEY=

# abuse.ch API keys (all free at https://auth.abuse.ch/)
# URLhaus: increases URL feed access
URLHAUS_API_KEY=
# ThreatFox: required to ingest IOC feed
THREATFOX_API_KEY=
# MalwareBazaar: required to ingest malware sample feed
MALWARE_BAZAAR_KEY=

# VulnCheck community token (free at https://vulncheck.com/token)
# Required to ingest VulnCheck KEV feed
VULNCHECK_TOKEN=

# Feed polling intervals (minutes)
POLL_INTERVAL_FAST=15
POLL_INTERVAL_SLOW=60

# API server
HOST=127.0.0.1
PORT=8000

# SQLite database path
DB_PATH=./phantomfeed.db

# Days of history to retain before purge
RETENTION_DAYS=90

# Max CVEs fetched per NVD API page (max 2000)
NVD_PAGE_SIZE=200

# Auth — generate a strong random SECRET_KEY for production
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ADMIN_PASSWORD=phantomfeed-admin
ACCESS_TOKEN_EXPIRE_MINUTES=480

# FedRAMP 20x — Fernet key for encrypting stored scanner/SIEM credentials
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, credentials are stored in plaintext
PHANTOMFEED_ENCRYPTION_KEY=

# SMTP (for weekly email digests — all optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# TAXII 2.1 credentials (all optional)
TAXII_USERNAME=
TAXII_PASSWORD=
TAXII_CERT_PATH=

# IOC Enrichment API keys (all optional — free tiers available)
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
GREYNOISE_API_KEY=

# MSP-level Slack alert webhook (optional — critical items alert)
ADMIN_SLACK_WEBHOOK=

# Dark web monitoring (all optional)
# HIBP API key — required for per-domain breach lookup (https://haveibeenpwned.com/API/Key)
HIBP_API_KEY=
# GitHub personal access token — increases Gist API rate limits from 60 to 5000/hour
GITHUB_TOKEN=
# Telegram bot token — for sending dark web alerts via Telegram (optional)
TELEGRAM_BOT_TOKEN=

# MISP integration (optional — requires self-hosted or cloud MISP instance)
MISP_URL=
MISP_API_KEY=
MISP_VERIFY_SSL=true
MISP_SHARING_GROUP=

# MSP branding (used in report footers and briefing decks)
MSP_NAME=PhantomFeed MSP
MSP_EMAIL=
MSP_PHONE=
