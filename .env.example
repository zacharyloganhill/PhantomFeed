# HexIntel Environment Configuration
# Copy this to .env and fill in your values

# NVD API Key (free at https://nvd.nist.gov/developers/request-an-api-key)
# Without a key: 5 req/30s. With key: 50 req/30s.
NVD_API_KEY=

# AlienVault OTX API Key (free at https://otx.alienvault.com)
OTX_API_KEY=

# How often to poll feeds (in minutes)
POLL_INTERVAL_FAST=15
POLL_INTERVAL_SLOW=60

# API server settings
HOST=127.0.0.1
PORT=8000

# SQLite database path
DB_PATH=./threatpulse.db

# Days of history to retain
RETENTION_DAYS=90

# Max items to fetch from NVD per poll (max 2000)
NVD_PAGE_SIZE=200
